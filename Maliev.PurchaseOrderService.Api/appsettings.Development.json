{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "PurchaseOrderDbContext": "Server=localhost;Port=5432;Database=purchaseorder_dev_db;Username=postgres;Password=postgres;"
  },
  "ExternalServices": {
    "SupplierService": {
      "BaseUrl": "http://localhost:8080/suppliers",
      "TimeoutInSeconds": 30
    },
    "OrderService": {
      "BaseUrl": "http://localhost:8081/orders",
      "TimeoutInSeconds": 30
    },
    "CurrencyService": {
      "BaseUrl": "http://localhost:8082/currencies",
      "TimeoutInSeconds": 30
    },
    "UploadService": {
      "BaseUrl": "http://localhost:8083/uploads",
      "TimeoutInSeconds": 60
    },
    "PdfService": {
      "BaseUrl": "http://localhost:8084/pdfs",
      "TimeoutInSeconds": 120
    },
    "AuthService": {
      "BaseUrl": "http://localhost:8085/auth",
      "TimeoutInSeconds": 10
    }
  },
  "Application": {
    "Environment": "Development",
    "PdfGenerationEnabled": false
  },
  "Security": {
    "RequireHttps": false,
    "EnableVirusScanning": false,
    "JwtSettings": {
      "ValidateIssuer": false,
      "ValidateAudience": false
    }
  },
  "HealthChecks": {
    "EnableDetailedErrors": true,
    "TimeoutInSeconds": 10,
    "ExternalServicesCheckEnabled": false
  }
}
