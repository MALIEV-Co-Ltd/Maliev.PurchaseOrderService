{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Properties": {
      "Application": "PurchaseOrderService"
    }
  },
  "ConnectionStrings": {
    "PurchaseOrderDbContext": "Server=${DB_SERVER};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};"
  },
  "AllowedHosts": "*",
  "ExternalServices": {
    "SupplierService": {
      "BaseUrl": "${SUPPLIER_SERVICE_URL}",
      "TimeoutInSeconds": 30,
      "RetryCount": 3,
      "CircuitBreakerThreshold": 5,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 1000,
      "RetryJitterMs": 100
    },
    "OrderService": {
      "BaseUrl": "${ORDER_SERVICE_URL}",
      "TimeoutInSeconds": 30,
      "RetryCount": 3,
      "CircuitBreakerThreshold": 5,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 1000,
      "RetryJitterMs": 100
    },
    "CurrencyService": {
      "BaseUrl": "${CURRENCY_SERVICE_URL}",
      "TimeoutInSeconds": 15,
      "RetryCount": 2,
      "CircuitBreakerThreshold": 3,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 500,
      "RetryJitterMs": 50
    },
    "UploadService": {
      "BaseUrl": "${UPLOAD_SERVICE_URL}",
      "TimeoutInSeconds": 60,
      "RetryCount": 2,
      "CircuitBreakerThreshold": 3,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 1500,
      "RetryJitterMs": 200
    },
    "PdfService": {
      "BaseUrl": "${PDF_SERVICE_URL}",
      "TimeoutInSeconds": 45,
      "RetryCount": 2,
      "CircuitBreakerThreshold": 3,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 2000,
      "RetryJitterMs": 300
    },
    "AuthService": {
      "BaseUrl": "${AUTH_SERVICE_URL}",
      "TimeoutInSeconds": 15,
      "RetryCount": 2,
      "CircuitBreakerThreshold": 3,
      "CircuitBreakerDurationInSeconds": 30,
      "EnableRetryPolicy": true,
      "EnableCircuitBreaker": true,
      "RetryBaseDelayMs": 500,
      "RetryJitterMs": 50
    }
  },
  "Cache": {
    "DefaultExpirationMinutes": 30,
    "PurchaseOrderCacheExpirationMinutes": 15
  },
  "Application": {
    "ServiceName": "PurchaseOrderService",
    "Version": "1.0.0"
  },
  "Security": {
    "RequireHttps": true,
    "JwtSettings": {
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ValidateIssuerSigningKey": true,
      "ClockSkew": "00:05:00"
    }
  },
  "HealthChecks": {
    "EnableDetailedErrors": false,
    "TimeoutInSeconds": 30
  }
}