{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PurchaseOrderDbContext": "PLACEHOLDER_FROM_SECRETS"
  },
  "Redis": {
    "ConnectionString": "PLACEHOLDER_FROM_SECRETS",
    "Enabled": "false"
  },
  "CORS": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Jwt": {
    "Issuer": "PLACEHOLDER_FROM_SECRETS",
    "Audience": "PLACEHOLDER_FROM_SECRETS",
    "PublicKey": ""
  },
  "ExternalServices": {
    "SupplierService": {
      "BaseUrl": "http://localhost/suppliers",
      "TimeoutInSeconds": 30
    },
    "OrderService": {
      "BaseUrl": "http://localhost/orders",
      "TimeoutInSeconds": 30
    },
    "CurrencyService": {
      "BaseUrl": "http://localhost/currencies",
      "TimeoutInSeconds": 30
    },
    "UploadService": {
      "BaseUrl": "http://localhost/uploads",
      "TimeoutInSeconds": 30
    },
    "PdfService": {
      "BaseUrl": "http://localhost/pdfs",
      "TimeoutInSeconds": 30
    }
  }
}