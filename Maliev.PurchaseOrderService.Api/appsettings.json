{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PurchaseOrderDbContext": "PLACEHOLDER_FROM_SECRETS"
  },
  "Redis": {
    "ConnectionString": "PLACEHOLDER_FROM_SECRETS",
    "Enabled": "false"
  },
  "CORS": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Jwt": {
    "Issuer": "PLACEHOLDER_FROM_SECRETS",
    "Audience": "PLACEHOLDER_FROM_SECRETS",
    "PublicKey": ""
  },
  "ExternalServices": {
    "SupplierService": {
      "BaseUrl": "http://localhost/suppliers",
      "TimeoutInSeconds": 30
    },
    "OrderService": {
      "BaseUrl": "http://localhost/orders",
      "TimeoutInSeconds": 30
    },
    "CurrencyService": {
      "BaseUrl": "http://localhost/currencies",
      "TimeoutInSeconds": 30
    },
    "UploadService": {
      "BaseUrl": "http://localhost/uploads",
      "TimeoutInSeconds": 30
    },
    "PdfService": {
      "BaseUrl": "http://localhost/pdfs",
      "TimeoutInSeconds": 30
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  }
}