<?xml version="1.0" encoding="utf-8"?>
<RuleSet Name="StyleCop Rules" Description="StyleCop analyzer rules for this project" ToolsVersion="17.0">
  <Rules AnalyzerId="StyleCop.Analyzers" RuleNamespace="StyleCop.Analyzers">
    <!-- Documentation Rules -->
    <Rule Id="SA1633" Action="None" />  <!-- File header missing -->
    <Rule Id="SA1652" Action="None" />  <!-- Enable XML documentation output -->
    <Rule Id="SA0001" Action="None" />  <!-- XML comment analysis disabled -->

    <!-- Layout Rules -->
    <Rule Id="SA1507" Action="None" />  <!-- Multiple blank lines -->
    <Rule Id="SA1518" Action="None" />  <!-- File must end with newline -->
    <Rule Id="SA1128" Action="None" />  <!-- Constructor initializers on own line -->
    <Rule Id="SA1116" Action="None" />  <!-- Parameters should begin on line after declaration -->

    <!-- Readability Rules -->
    <Rule Id="SA1101" Action="None" />  <!-- Prefix local calls with this -->
    <Rule Id="SA1413" Action="None" />  <!-- Use trailing comma in multi-line initializers -->

    <!-- Ordering Rules -->
    <Rule Id="SA1210" Action="None" />  <!-- Using directives should be ordered alphabetically -->
    <Rule Id="SA1202" Action="None" />  <!-- Members should be ordered by access level -->

    <!-- Spacing Rules -->
    <Rule Id="SA1011" Action="None" />  <!-- Closing square bracket should be followed by a space -->

    <!-- Layout Rules Additional -->
    <Rule Id="SA1508" Action="None" />  <!-- Closing brace should not be preceded by a blank line -->
  </Rules>
</RuleSet>